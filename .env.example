# Supabase (our own project) — client-side, publishable key, NOT the secret key.
# Holds partners / attendance and is set in Vercel project settings.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Company bookings DB — SERVER-SIDE ONLY (no VITE_ prefix → never shipped to browser).
# Used by api/bookings.js to read live demand from public.bookings.
# Set this in Vercel project settings; do NOT commit a real value.
BOOKINGS_DB_URL=postgresql://user:password@host.pooler.supabase.com:5432/postgres

# Local dev only: point the frontend at the deployed /api so `vite` dev gets live
# demand. Leave UNSET in production (same-origin /api is used automatically).
# VITE_API_BASE=https://supply-shaping.vercel.app
